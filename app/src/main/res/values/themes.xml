<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash screen theme -->
    <style name="Theme.NfcTagMaestro.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF0A0A0F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.NfcTagMaestro</item>
    </style>

    <!-- Main app theme -->
    <style name="Theme.NfcTagMaestro" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#FF0A0A0F</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
